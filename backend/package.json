{
  "name": "bugboard26-backend",
  "version": "0.1.0",
  "private": true,
  "description": "REST backend for BugBoard26",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "start": "node --env-file-if-exists=../.env --env-file-if-exists=.env src/server.js",
    "dev": "node --env-file-if-exists=../.env --env-file-if-exists=.env --watch src/server.js",
    "check": "node --check src/server.js",
    "test:unit": "vitest run --reporter=verbose",
    "db:migrate": "node --env-file-if-exists=../.env --env-file-if-exists=.env scripts/migrate-database.mjs",
    "db:import-sqlite": "node --env-file-if-exists=../.env --env-file-if-exists=.env scripts/import-sqlite-to-postgres.mjs",
    "healthcheck": "node scripts/healthcheck.mjs",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
